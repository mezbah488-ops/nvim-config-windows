}, 
	"Math Bold": {
    "prefix": "mbo",
    "body": "\\mathbf{${1:p}}${0}",
    "description": "Insert mathbf (bold) font"
},
	"Quadruple Integral": {
    "prefix": "int4",
    "body": "\\iiiint_{${1:V}} ${2:f}(${3:x}) \\, d^4${3:x} ${0}",
    "description": "Insert explicit quadruple integral"
},
	"4D Momentum Integral": {
    "prefix": "d4p",
    "body": "\\int \\frac{d^4 ${1:p}}{(2 \\pi)^4} ${0}",
    "description": "Insert 4D momentum space integral measure"
},
	"Momentum Space Integral": {
    "prefix": "d3p",
    "body": "\\int \\frac{d^3 ${1:p}}{(2 \\pi)^3} ${0}",
