},
	"Commutator": {
    "prefix": "comm",
    "body": "[ ${1:A}, ${2:B} ]${0}",
    "description": "Insert commutator [A, B]"
},
"Anti-commutator": {
    "prefix": "acomm",
    "body": "\\{ ${1:A}, ${2:B} \\}${0}",
    "description": "Insert anti-commutator {A, B}"
},
    "Equation Reference": {
    "prefix": "eqr",
    "body": "Eq.(\\ref{eq:${1:label}})${0}",
    "description": "Insert 'eq. (label)' reference"
},
	"Relativistic Energy": {
    "prefix": "enp",
    "body": "\\sqrt{\\mathbf{${1:p}}^2 + ${2:m}^2}${0}",
