{
	"Inkscape Figure": {
    "prefix": "incfig",
    "body": [
        "\\begin{figure}[ht]",
        "\t\\centering",
        "\t\\incfig[0.5\\columnwidth]{${1:figure_name}}",
        "\t\\caption{${2:Your caption here}}",
        "\\end{figure}"
    ],
    "description": "Insert Inkscape figure with 0.8 columnwidth"
},
	"Exercise (tcolorbox)": {
    "prefix": "ex",
    "body": [
        "\\begin{exercise}{${1}}{${2:label}}",
        "\t${3:Exercise content here...}",
        "\\end{exercise}"
    ],
    "description": "Insert tcolorbox exercise environment"
},
	"Exercise Reference": {
    "prefix": "exref",
    "body": "\\ref{ex:${1:label}}",
    "description": "Reference an exercise by its label"
},
	"Unnumbered align": {
    "prefix": "al",
    "body": "\\begin{align*}\n\t$1\n\\end{align*}",
    "description": "Insert unnumbered align environment"
},
"Unnumbered equation": {
    "prefix": "eq",
    "body": "\\[\n\t$1\n\\]",
    "description": "Insert unnumbered equation"
},
	"LaTeX environment": {
    "prefix": "env",
    "body": [
        "\\begin{$1}",
        "\t$0",
        "\\end{$1}"
    ],
    "description": "LaTeX environment with mirrored name"
},
	"Implies symbol": {
    "prefix": "implies",
    "body": "\\implies",
    "description": "Implies symbol (⟹)"
},
	"Doteq symbol": {
    "prefix": "doteq",
    "body": "\\doteq",
    "description": "Dot over equals symbol (≐)"
},
	"Reference": {
    "prefix": "ref",
    "body": "\\ref{${1}}${0}",
    "description": "Insert reference"
},
"Scri": {
    "prefix": "scr",
    "body": "\\mathscr{${1}}${0}",
    "description": "Insert mathscr"
}, 
	"2x2 Matrix": {
    "prefix": "mat2",
    "body": "\\begin{pmatrix}\n${1:a} & ${2:b} \\\\\\\\\n${3:c} & ${4:d}\n\\end{pmatrix}${0}",
    "description": "Insert 2x2 matrix"
},
	"Dot Above": {
    "prefix": "dot",
    "body": "\\dot{${1:letter}}${0}",
    "description": "Insert dot above letter"
},
"Double Dot": {
    "prefix": "ddot",
    "body": "\\ddot{${1:letter}}${0}",
    "description": "Insert double dot above letter"
},
	"Quad Space": {
    "prefix": "space",
    "body": "\\quad${0}",
    "description": "Insert quad space in math mode"
},
	"Belongs To": {
    "prefix": "in",
    "body": "\\in${0}",
    "description": "Insert belongs to symbol ∈"
},
	"Theorem Environment": {
    "prefix": "thm",
    "body": "\\begin{theorem}[${1:title}]\n\t${2:statement}\n\\end{theorem}${0}",
    "description": "Insert theorem environment"
},
	"Plus Minus": {
    "prefix": "pm",
    "body": "\\pm${0}",
    "description": "Insert plus minus symbol ±"
}, 
	"Nabla": {
    "prefix": "nab",
    "body": "\\nabla${0}",
    "description": "Insert nabla symbol"
},
	"Bold Symbol": {
    "prefix": "boldsymbol",
    "body": "\\boldsymbol{${1:symbol}}${0}",
    "description": "Insert bold math symbol using boldsymbol"
},
	"Bold Nabla": {
    "prefix": "nabla",
    "body": "\\boldsymbol{\\nabla}${0}",
    "description": "Insert boldface nabla symbol"
},
	"Underset with Two Conditions": {
    "prefix": "us2",
    "body": "\\underset{\\substack{\\scriptstyle ${1:condition1}\\\\ \\scriptstyle ${2:condition2}}}{${3:expression}}${0}",
    "description": "Insert underset with two scriptstyle conditions using substack"
},
"Underset with One Condition": {
    "prefix": "us1",
    "body": "\\underset{\\substack{\\scriptstyle ${1:condition}}}{${2:expression}}${0}",
    "description": "Insert underset with one scriptstyle condition using substack"
},
	"Plus Sign": {
    "prefix": "p",
    "body": "+${0}",
    "description": "Insert plus sign +"
},
"Minus Sign": {
    "prefix": "m",
    "body": "-${0}",
    "description": "Insert minus sign -"
},
"Equal Sign": {
    "prefix": "e",
    "body": "=${0}",
    "description": "Insert equal sign ="
},
	"Limit": {
    "prefix": "lim",
    "body": "\\lim_{${1:variable} \\to ${2:value}} ${3:expression}${0}",
    "description": "Insert limit with variable approaching value"
},
	"Expectation Value": {
    "prefix": "expval",
    "body": "\\langle ${1:state1} | ${2:operator} | ${3:state2} \\rangle${0}",
    "description": "Insert expectation value ⟨state1|operator|state2⟩"
}, 
	"Expectation Value (Same State)": {
    "prefix": "expvals",
    "body": "\\langle ${1:state} | ${2:operator} | ${1:state} \\rangle${0}",
    "description": "Insert expectation value ⟨state|operator|state⟩ with same state"
},
	"Underbrace": {
    "prefix": "under",
    "body": "\\underbrace{${1:expression}}_{${2:label}}${0}",
    "description": "Insert underbrace with expression and label"
},
	"Overset": {
    "prefix": "overset",
    "body": "\\overset{${1:above}}{${2:main}}${0}",
    "description": "Insert overset with content above the main expression"
},
"Underset": {
    "prefix": "underset",
    "body": "\\underset{${1:below}}{${2:main}}${0}",
    "description": "Insert underset with content below the main expression"
},
	"First Order Derivative": {
    "prefix": "d1",
    "body": "\\frac{d ${1:y}}{d ${2:x}}${0}",
    "description": "Insert first order derivative dy/dx"
}, 
	"Second Order Derivative": {
    "prefix": "d2",
    "body": "\\frac{d^{2}${1:y}}{d ${2:x}^{2}}${0}",
    "description": "Insert second order derivative d²y/dx²"
},
	"Third Order Derivative": {
    "prefix": "d3",
    "body": "\\frac{d^{3} ${1:y}}{d ${2:x}^{3}}${0}",
    "description": "Insert third order derivative d³y/dx³"
},
	"Bra-Ket Notation": {
    "prefix": "bra",
    "body": "\\langle ${1:ψ} |",
    "description": "Insert bra notation ⟨ψ|"
},
"Ket-Ket Notation": {
    "prefix": "ket",
    "body": "| ${1:ψ} \\rangle",
    "description": "Insert ket notation |ψ⟩"
},
"Inner Notation": {
    "prefix": "inner",
    "body": "\\langle ${1:ψ} | ${2:φ} \\rangle",
    "description": "Insert bra-ket inner product ⟨ψ|φ⟩"
},
	"Another Inner Notation": {
    "prefix": "innercomma",
    "body": "\\langle ${1:ψ} , ${2:φ} \\rangle",
    "description": "Insert bra-ket inner product ⟨ψ,φ⟩"
},
"Outer Product": {
    "prefix": "outer",
    "body": "| ${1:ψ} \\rangle \\langle ${2:φ} |",
    "description": "Insert outer product |ψ⟩⟨φ|"
},
	"Infinity Symbol": {
    "prefix": "inf",
    "body": "\\infty${0}",
    "description": "Insert infinity symbol in math mode"
},
	"Double Right Arrow": {
    "prefix": "Rightarrow",
    "body": "\\Rightarrow${0}",
    "description": "Insert double right arrow in math mode"
},
	"Right Arrow": {
    "prefix": "rightarrow",
    "body": "\\rightarrow${0}",
    "description": "Insert right arrow in math mode"
},
	"Hat Accent": {
    "prefix": "hat",
    "body": "\\hat{${1:symbol}}${0}",
    "description": "Insert hat accent over a symbol in math mode"
},
	"Math Text": {
    "prefix": "text",
    "body": "\\text{${1:label}}${0}",
    "description": "Insert text inside math mode"
},
	"Bold": {
    "prefix": "bf",
    "body": "\\textbf{${0}}", 
    "description": "Insert bold font"
},
	"Italic": {
    "prefix": "it",
    "body": "\\textit{${0}}", 
    "description": "Insert italic font"
},
	"Ellipsis (Dots)": {
    "prefix": "dots",
    "body": "\\dots ${0}",
    "description": "Insert centered ellipsis (...)"
},
	"Big O Notation": {
    "prefix": "bo",
    "body": "\\mathcal{O}(${1:x^2})${0}",
    "description": "Insert Big O notation O(x^2)"
},
	"Much Less Than": {
    "prefix": "ll",
    "body": "\\ll ${0}",
    "description": "Insert much less than symbol \\ll"
},
        "Much Greater Than": {
    "prefix": "gg",
    "body": "\\gg ${0}",
    "description": "Insert much greater than symbol \\gg"
},
	"Approximation": {
    "prefix": "appr",
    "body": "\\approx ${0}",
    "description": "Insert approximation symbol \\approx"
},
	"Congruence": {
    "prefix": "congru",
    "body": "\\cong ${0}",
    "description": "Insert congruence symbol \\cong"
},
	"Inline Math": {
    "prefix": "i",
    "body": "\\$$1\\$${0}",
    "description": "Insert inline math mode $ $"
},
	"Numbered Equation with Label": {
    "prefix": "eqlabel",
    "body": [
        "\\begin{equation}",
        "\t${1:formula} \\label{eq:${2:name}}",
        "\\end{equation}${0}"
    ],
    "description": "Insert a numbered equation with a reference label"
},
	"Label Equation": {
    "prefix": "lab",
    "body": "\\label{eq:${1:name}}${0}",
    "description": "Insert an equation label with eq: prefix"
},
	"Order of Magnitude": {
    "prefix": "ord",
    "body": "\\mathcal{O}(${1:y^4})${0}",
    "description": "Insert Big-O notation using mathcal"
},
	"Sim": {
    "prefix": "sim",
    "body": "\\sim ${0}",
