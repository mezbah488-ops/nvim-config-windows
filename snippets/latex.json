},
"First Bracket (Parentheses) [No Scaling]": {
    "prefix": "fir",
    "body": "($1)${0}",
    "description": "Standard parentheses ( ) no scaling"
},
"Second Bracket (Curly) [No Scaling]": {
    "prefix": "sec",
    "body": "\\{$1\\}${0}",
    "description": "Standard curly braces { } no scaling"
},
"Third Bracket (Square) [No Scaling]": {
    "prefix": "thir",
    "body": "[$1]${0}",
